{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "paths": {
      "@historial/shared-types": ["./packages/shared-types/src/index.ts"],
      "@historial/validators": ["./packages/validators/src/index.ts"],
      "@historial/constants": ["./packages/constants/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
