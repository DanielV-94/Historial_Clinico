# Database
POSTGRES_USER=historial
POSTGRES_PASSWORD=historial_dev
POSTGRES_DB=historial_clinico
DATABASE_URL=postgresql://historial:historial_dev@localhost:5432/historial_clinico

# Redis
REDIS_URL=redis://localhost:6379

# API
PORT=3000
CORS_ORIGIN=http://localhost:5173

# JWT
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=209715200

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Backup
BACKUP_DIR=./backups
BACKUP_ENCRYPTION_KEY=change-this-backup-encryption-key
BACKUP_RETENTION=12
